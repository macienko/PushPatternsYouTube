# === Google OAuth2 ===
# Obtain these by running: python setup_auth.py
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# === Google Drive ===
# Share both folders with the Google account used for OAuth2
SOURCE_DRIVE_FOLDER_ID=    # Drive folder to watch for new videos
CAPTIONS_DRIVE_FOLDER_ID=  # Drive folder to save .srt caption files

# === Polling Intervals ===
POLL_INTERVAL_MINUTES=5            # How often to scan Drive for new videos (default: 5)
CAPTION_CHECK_INTERVAL_MINUTES=15  # How often to check YouTube for captions (default: 15)
CAPTION_MAX_WAIT_HOURS=48          # Give up waiting for captions after this many hours (default: 48)

# === Database ===
# Provided automatically by Railway when the PostgreSQL add-on is attached
DATABASE_URL=

# === Server ===
# Provided automatically by Railway
PORT=8080
